# ── Example Environment Variables for setup-grafana.sh ──
# You can copy this file, modify it, and source it before 
# running the setup script in non-interactive mode.
# e.g., export $(grep -v '^#' .env.example | xargs) && sudo bash setup-grafana.sh --no-interaction

# General Setup
GRAFANA_DOMAIN="monitor.ravact.com"
GRAFANA_INSTALL_DIR="/opt/grafana"
GRAFANA_PORT="3000"
PROMETHEUS_PORT="9090"

# Admin Credentials
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASS="ChangeMeToASecurePassword!"

# Nginx reverse proxy and Let's Encrypt SSL config
SETUP_NGINX="true"
SETUP_SSL="true"
ADMIN_EMAIL="admin@ravact.com"

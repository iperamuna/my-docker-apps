# ==============================================================================
# Listmonk Environment Variables — Example File
# Copy to .env and fill in your real values.
# The setup-listmonk.sh script generates this automatically.
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
LISTMONK_DOMAIN=newsletter.yourdomain.com
LISTMONK_APP_PORT=9000
LISTMONK_INSTALL_DIR=/opt/listmonk

# ── Admin Credentials (used during --install; change via UI afterwards) ───────
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASS=change_me_strong_password

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_USER=listmonk
POSTGRES_DB=listmonk

# ── SMTP — Mailu Internal Connection (NO SSL / No handshake) ─────────────────
# When Listmonk joins the 'mailu_default' Docker network, it can reach Mailu's
# 'front' container directly on port 25 — plain SMTP, no TLS handshake.
# This is safe because communication stays inside Docker's bridge network.
#
#   Port 25  → Plain SMTP (no encryption)     ← recommended for internal
#   Port 587 → STARTTLS                        ← use if security policy requires
#   Port 465 → SMTPS (SSL/TLS from connect)   ← not recommended internally
#
SMTP_HOST=front                          # Mailu's front container hostname
SMTP_PORT=25                             # Plain SMTP — no handshake overhead
SMTP_USER=listmonk@yourdomain.com        # Must exist as a Mailu mailbox
SMTP_PASS=your_mailu_mailbox_password
SMTP_FROM=Listmonk <listmonk@yourdomain.com>
SMTP_TLS=false                           # No SSL/TLS for internal
SMTP_STARTTLS=false                      # No STARTTLS for internal

# ── Docker Network ────────────────────────────────────────────────────────────
JOIN_MAILU_NETWORK=true
MAILU_NETWORK=mailu_default              # Match the network name in Mailu's compose

# ── Nginx & SSL ───────────────────────────────────────────────────────────────
SETUP_NGINX=true
SETUP_SSL=true
ADMIN_EMAIL=admin@yourdomain.com

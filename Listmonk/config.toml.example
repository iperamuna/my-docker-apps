# ==============================================================================
# Listmonk config.toml — Reference Template
# Generated by setup-listmonk.sh with your real values.
# This file is mounted into the Listmonk container as a read-only volume.
# ==============================================================================

[app]
address          = "0.0.0.0:9000"
admin_username   = "admin"
admin_password   = "change_me"

# Uncomment to restrict the admin panel to specific IPs
# admin_ip_networks = ["127.0.0.1/32", "10.0.0.0/8"]

[db]
host         = "listmonk-db"
port         = 5432
user         = "listmonk"
password     = "change_me"
database     = "listmonk"
ssl_mode     = "disable"
max_open     = 25
max_idle     = 25
max_lifetime = "300s"

# ==============================================================================
# SMTP Block — Mailu Internal (no TLS, no handshake overhead)
# ────────────────────────────────────────────────────────────────────────────
# tls_type options:
#   "none"     → port 25  plain SMTP       ← for internal Mailu (recommended)
#   "STARTTLS" → port 587 upgrade to TLS   ← when policy requires encryption
#   "TLS"      → port 465 TLS from connect ← for external providers (SendGrid…)
# ==============================================================================
[[smtp]]
enabled          = true
host             = "front"          # Mailu 'front' container on shared Docker network
port             = 25               # Plain SMTP — no TLS handshake
auth_protocol    = "plain"          # "plain", "login", or "cram" — plain is fine internally
username         = "listmonk@yourdomain.com"
password         = "your_mailu_password"
email_headers    = []
max_conns        = 10               # concurrent connections to SMTP
max_msg_retries  = 2
idle_timeout     = "15s"
wait_timeout     = "5s"
tls_type         = "none"           # ← KEY: disables TLS/STARTTLS for internal use
tls_skip_verify  = false

# ── Optional second SMTP (e.g. external fallback) ────────────────────────────
# [[smtp]]
# enabled         = false
# host            = "smtp.sendgrid.net"
# port            = 587
# auth_protocol   = "plain"
# username        = "apikey"
# password        = "your_sendgrid_key"
# tls_type        = "STARTTLS"
# max_conns       = 5
# max_msg_retries = 2
# idle_timeout    = "15s"
# wait_timeout    = "5s"

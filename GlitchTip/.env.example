# GlitchTip Environment Configuration (Example)
# This file is generated/updated by setup-glitchtip.sh

GLITCHTIP_DOMAIN=https://gt.siyalude.io
APP_PORT=8000

# Secret Key (run: openssl rand -hex 32)
SECRET_KEY=change_me_to_something_random

# PostgreSQL Settings
POSTGRES_PASSWORD=secure_password_here

# SMTP Settings
# Example: smtp://user:pass@smtp.example.com:587
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=GlitchTip SIO <info@siyalude.io>

# Features
GLITCHTIP_ENABLE_UPTIME=True
GLITCHTIP_ENABLE_LOGS=True
ENABLE_ADMIN=True

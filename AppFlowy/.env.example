# AppFlowy Cloud Environment Configuration (Example)
# This file is for reference. The setup-appflowy.sh script generates a full .env based on deploy.env.

FQDN=af.siyalude.io
SCHEME=https
WS_SCHEME=wss

# PostgreSQL Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_here
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# Authentication
GOTRUE_ADMIN_EMAIL=admin@siyalude.io
GOTRUE_ADMIN_PASSWORD=change_this_password
GOTRUE_JWT_SECRET=random_jwt_secret_here
GOTRUE_SITE_URL=https://af.siyalude.io
GOTRUE_URI_ALLOW_LIST=https://af.siyalude.io/*

# SMTP (Resend) - Authentication Service
GOTRUE_SMTP_HOST=smtp.resend.com
GOTRUE_SMTP_PORT=465
GOTRUE_SMTP_USER=resend
GOTRUE_SMTP_PASS=resend_api_key
GOTRUE_SMTP_ADMIN_EMAIL=AF SiyaludeIO <info@siyalude.io>

# SMTP (Resend) - AppFlowy Mailer Service
APPFLOWY_MAILER_SMTP_HOST=smtp.resend.com
APPFLOWY_MAILER_SMTP_PORT=465
APPFLOWY_MAILER_SMTP_USERNAME=resend
APPFLOWY_MAILER_SMTP_PASSWORD=resend_api_key
APPFLOWY_MAILER_SMTP_EMAIL=AF SiyaludeIO <info@siyalude.io>
APPFLOWY_MAILER_SMTP_TLS_KIND=wrapper

# Internal Port for AppFlowy Nginx (Host Nginx will proxy to this)
NGINX_PORT=8080
NGINX_TLS_PORT=8443
